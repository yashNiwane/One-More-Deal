# One More Deal — Environment Configuration
# Duplicate this file to .env and fill in your details

# Core API and URL configuration
# BASE_URL=https://api.onemoredeal.com

# Authentication & Keys
# GEMINI_API_KEY=your_key_here
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_anon_key

# Payment Providers
# INSTAMOJO_API_KEY=your_instamojo_apiKey
# INSTAMOJO_AUTH_TOKEN=your_instamojo_authToken

# OTP
# MSG91=your_msg91_key

# AWS RDS PostgreSQL
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=your_db_name
# DB_USER=postgres
# DB_PASSWORD=your_password
